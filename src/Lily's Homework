class Result {

    /*
     * Complete the 'lilysHomework' function below.
     *
     * The function is expected to return an INTEGER.
     * The function accepts INTEGER_ARRAY arr as parameter.
     */

    public static int lilysHomework(List<Integer> arr) {
        int n = arr.size();

        // Create pairs of (element value, original index) to sort later
        int[][] sortedAsc = new int[n][2];
        int[][] sortedDesc = new int[n][2];

        for (int i = 0; i < n; i++) {
            int val = arr.get(i);
            sortedAsc[i][0] = val;
            sortedAsc[i][1] = i;
            
            sortedDesc[i][0] = val;
            sortedDesc[i][1] = i;
        }

        // Sort ascending by value
        Arrays.sort(sortedAsc, new Comparator<int[]>() {
            @Override
            public int compare(int[] a, int[] b) {
                return Integer.compare(a[0], b[0]);
            }
        });

        // Sort descending by value
        Arrays.sort(sortedDesc, new Comparator<int[]>() {
            @Override
            public int compare(int[] a, int[] b) {
                return Integer.compare(b[0], a[0]);
            }
        });

        // Compute minimum swaps required for both conditions
        int ascSwaps = countMinSwaps(arr, sortedAsc);
        int descSwaps = countMinSwaps(arr, sortedDesc);

        return Math.min(ascSwaps, descSwaps); // Return the true absolute minimum swaps needed[cite: 27]
    }

    // Helper method to count cycles/swaps needed to match a specific sorted goal configuration
    private static int countMinSwaps(List<Integer> original, int[][] targetSorted) {
        int n = original.size();
        boolean[] visited = new boolean[n];
        int swaps = 0;

        // Map containing current tracking positions of items based on value
        Map<Integer, Integer> currentPosMap = new HashMap<Integer, Integer>();
        for (int i = 0; i < n; i++) {
            currentPosMap.put(original.get(i), i);
        }

        for (int i = 0; i < n; i++) {
            // If already processed or already in the correct position, continue
            if (visited[i] || targetSorted[i][1] == i) {
                continue;
            }

            // Find the size of the permutation cycle
            int cycleSize = 0;
            int j = i;

            while (!visited[j]) {
                visited[j] = true;
                // Next index in the cycle is where the element currently sitting at j belongs
                int correctValue = targetSorted[j][0];
                j = currentPosMap.get(correctValue);
                cycleSize++;
            }

            if (cycleSize > 0) {
                swaps += (cycleSize - 1);
            }
        }

        return swaps;
    }

}

public class Solution {
    public static void main(String[] args) throws IOException {
        BufferedReader bufferedReader = new BufferedReader(new InputStreamReader(System.in));
        BufferedWriter bufferedWriter = new BufferedWriter(new FileWriter(System.getenv("OUTPUT_PATH")));

        int n = Integer.parseInt(bufferedReader.readLine().trim());

        String[] arrTemp = bufferedReader.readLine().replaceAll("\\s+$", "").split(" ");

        List<Integer> arr = new ArrayList<Integer>();

        for (int i = 0; i < n; i++) {
            int arrItem = Integer.parseInt(arrTemp[i]);
            arr.add(arrItem);
        }

        int result = Result.lilysHomework(arr);

        bufferedWriter.write(String.valueOf(result));
        bufferedWriter.newLine();

        bufferedReader.close();
        bufferedWriter.close();
    }
}
